-- ── Config I/O ────────────────────────────────────────────────
local CFile, COn = nil, false
local function PackC(c)   return { R=c.R*255, G=c.G*255, B=c.B*255 } end
local function UnpackC(t) return Color3.fromRGB(t.R, t.G, t.B) end

local function SaveCfg()
    if not COn then return end
    local d = {}
    for i, v in pairs(Library.Flags) do
        d[i] = v.Type == "ColorPicker" and PackC(v.Color)
             or (v.CurrentValue or v.CurrentKeybind or v.CurrentOption or v.Color)
    end
    pcall(writefile, ConfigurationFolder.."/"..CFile..ConfigurationExtension,
          HttpService:JSONEncode(d))
end

local function LoadCfg(raw)
    local ok, d = pcall(HttpService.JSONDecode, HttpService, raw)
    if not ok then return end
    for k, v in pairs(d) do
        if Library.Flags[k] then
            task.spawn(function()
                if Library.Flags[k].Type == "ColorPicker" then Library.Flags[k]:Set(UnpackC(v))
                else Library.Flags[k]:Set(v) end
            end)
        end
    end
end

