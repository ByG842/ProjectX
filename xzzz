    local function SelectTab(ref, page)
        for _, r in pairs(TabBtns) do
            Tw(r.Bar,   0.18, { BackgroundTransparency = 1 })
            Tw(r.Lbl,   0.18, { TextColor3 = PAL.SubText })
            Tw(r.Icon,  0.18, { ImageColor3 = PAL.SubText })
