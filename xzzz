                    New("UIStroke",{Color=PAL.Border,Thickness=1,Transparency=0.4,ApplyStrokeMode=Enum.ApplyStrokeMode.Border}),
                    New("UIPadding",{PaddingLeft=UDim.new(0,9),PaddingRight=UDim.new(0,9)}),
                })
                chipBtns[item]=chip; upd(item,chip)
                chip.MouseButton1Click:Connect(function()
                    if val[item] then val[item]=nil
                    else if not multi then val={} end; val[item]=true end
                    for it,b in pairs(chipBtns) do upd(it,b) end
                    local sel={}; for _,it in ipairs(items) do if val[it] then table.insert(sel,it) end end
                    Call(cfg.Callback,sel)
                end)
            end
            local ch={Value=val,Type="Chip"}
            function ch:SetValue(v) val={}; if type(v)=="table" then for _,x in ipairs(v) do val[x]=true end end
                for it,b in pairs(chipBtns) do upd(it,b) end end
            Library.Options[idx]=ch; return ch
        end

        -- ── StatusIndicator ───────────────────────
        function Tab:CreateStatusIndicator(idx, cfg)
            cfg=cfg or {}
            local sCols={online=PAL.Good,offline=PAL.Dim,running=tabAccent,stopped=PAL.Bad,warning=PAL.Warn}
            local status=cfg.Status or "offline"
            local row,_=MakeRow(page,cfg.Title or idx,cfg.Description,tabAccent)
            local dot=New("Frame",{Size=UDim2.fromOffset(8,8),Position=UDim2.new(1,-56,0.5,-4),
                BackgroundColor3=sCols[status] or sCols.offline,Parent=row,ZIndex=4,})
            local lbl=New("TextLabel",{Text=status,
                FontFace=Font.new("rbxasset://fonts/families/RobotoMono.json"),
                TextSize=10,TextColor3=PAL.SubText,BackgroundTransparency=1,
                Size=UDim2.fromOffset(42,14),Position=UDim2.new(1,-10,0.5,-7),
                TextXAlignment=Enum.TextXAlignment.Right,Parent=row,ZIndex=4,})
            local si={Status=status,Type="StatusIndicator"}
            function si:SetStatus(s)
                self.Status=s; Tw(dot,0.2,{BackgroundColor3=sCols[s] or sCols.offline}); lbl.Text=s
            end
            Library.Options[idx]=si; return si
        end

        -- ── CounterButton ─────────────────────────
        function Tab:CreateCounterButton(idx, cfg)
            cfg=cfg or {}
            local val=cfg.Default or 1; local step=cfg.Step or 1
            local mn=cfg.Min or 1; local mx=cfg.Max or 99
            local row,_=MakeRow(page,cfg.Title or idx,cfg.Description,tabAccent)
            local h=New("Frame",{Size=UDim2.fromOffset(96,26),Position=UDim2.new(1,-106,0.5,-13),
                BackgroundTransparency=1,Parent=row,},{
                New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center}),
            })
            local function mkB(txt,lo)
                return New("TextButton",{Text=txt,
                    FontFace=Font.new("rbxasset://fonts/families/RobotoMono.json",Enum.FontWeight.Bold),
                    TextSize=14,Size=UDim2.fromOffset(26,26),BackgroundColor3=PAL.Panel,
                    TextColor3=tabAccent,LayoutOrder=lo,Parent=h,},{
                    New("UIStroke",{Color=PAL.Border,Thickness=1,ApplyStrokeMode=Enum.ApplyStrokeMode.Border}),
                })
            end
            local mB=mkB("−",1)
            local vL=New("TextLabel",{Text=tostring(val),
                FontFace=Font.new("rbxasset://fonts/families/RobotoMono.json",Enum.FontWeight.Bold),
                TextSize=11,Size=UDim2.fromOffset(44,26),BackgroundTransparency=1,
                TextXAlignment=Enum.TextXAlignment.Center,TextColor3=PAL.Text,LayoutOrder=2,Parent=h,})
            local pB=mkB("+",3)
            local cb={Value=val,Type="CounterButton"}
            local function set(v)
                v=math.clamp(math.floor(v/step+0.5)*step,mn,mx)
                cb.Value=v;val=v;vL.Text=tostring(v);Call(cfg.Callback,v)
            end
            mB.MouseButton1Click:Connect(function() set(val-step) end)
            pB.MouseButton1Click:Connect(function() set(val+step) end)
            function cb:SetValue(v) set(v) end
            Library.Options[idx]=cb; set(val); return cb
        end

        -- ── ToggleGroup ───────────────────────────
        function Tab:CreateToggleGroup(idx, cfg)
            cfg=cfg or {}
            local opts=cfg.Options or {}; local val=cfg.Default or opts[1]
            local row,_=MakeRow(page,cfg.Title or idx,cfg.Description,tabAccent)
            local row2=New("Frame",{Size=UDim2.fromOffset(0,24),AutomaticSize=Enum.AutomaticSize.X,
                Position=UDim2.new(1,-10,0.5,-12),AnchorPoint=Vector2.new(1,0),
                BackgroundColor3=PAL.Panel,BackgroundTransparency=0,Parent=row,},{
                New("UIStroke",{Color=PAL.Border,Thickness=1,ApplyStrokeMode=Enum.ApplyStrokeMode.Border}),
                New("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,VerticalAlignment=Enum.VerticalAlignment.Center}),
            })
            local btns={}
            local function upd(sel)
                for _,b in ipairs(btns) do
                    local active=b.V==sel
                    Tw(b.F,0.15,{BackgroundColor3=active and tabAccent or PAL.Panel,BackgroundTransparency=active and 0.3 or 0})
                    Tw(b.L,0.15,{TextColor3=active and PAL.Text or PAL.SubText})
                end
            end
            for _,opt in ipairs(opts) do
                local btn=New("TextButton",{Text="",Size=UDim2.fromOffset(0,24),AutomaticSize=Enum.AutomaticSize.X,
                    BackgroundTransparency=1,BackgroundColor3=tabAccent,Parent=row2,},{
                    New("UIPadding",{PaddingLeft=UDim.new(0,10),PaddingRight=UDim.new(0,10)}),
                })
                local lbl2=New("TextLabel",{Text=tostring(opt),
                    FontFace=Font.new("rbxasset://fonts/families/RobotoMono.json",Enum.FontWeight.Medium),
                    TextSize=10,BackgroundTransparency=1,Size=UDim2.fromScale(1,1),
                    AutomaticSize=Enum.AutomaticSize.X,TextColor3=PAL.SubText,Parent=btn,})
                table.insert(btns,{F=btn,L=lbl2,V=opt})
                btn.MouseButton1Click:Connect(function() val=opt;upd(opt);Call(cfg.Callback,opt) end)
            end
            upd(val)
            local tg={Value=val,Type="ToggleGroup"}
            function tg:SetValue(v) val=v;upd(v);Call(cfg.Callback,v) end
            Library.Options[idx]=tg; return tg
        end

        -- ── Accordion ─────────────────────────────
        function Tab:CreateAccordion(idx, cfg)
            cfg=cfg or {}
            local open=cfg.Open or false; local ANIM=0.2
            local outer=New("Frame",{Size=UDim2.new(1,-12,0,0),AutomaticSize=Enum.AutomaticSize.Y,
                BackgroundColor3=PAL.Panel,Parent=page,})
            New("Frame",{Size=UDim2.new(0,2,1,0),BackgroundColor3=tabAccent,BackgroundTransparency=0.55,Parent=outer})
            New("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),
                BackgroundColor3=PAL.Border,BackgroundTransparency=0.3,Parent=outer})
            local header=New("TextButton",{Size=UDim2.new(1,0,0,36),BackgroundTransparency=1,Text="",Parent=outer,ZIndex=5,})
            New("TextLabel",{Text=cfg.Title or "Accordion",
                FontFace=Font.new("rbxasset://fonts/families/RobotoMono.json",Enum.FontWeight.Bold),
                TextSize=11,TextColor3=PAL.Text,TextXAlignment=Enum.TextXAlignment.Left,
                BackgroundTransparency=1,Size=UDim2.new(1,-40,1,0),Position=UDim2.fromOffset(12,0),Parent=header,})
            local arr=New("TextLabel",{Text=open and "▲" or "▼",
                FontFace=Font.new("rbxasset://fonts/families/RobotoMono.json",Enum.FontWeight.Bold),
                TextSize=9,TextColor3=tabAccent,BackgroundTransparency=1,
                Size=UDim2.fromOffset(16,16),Position=UDim2.new(1,-24,0.5,-8),Parent=header,})
            local body=New("Frame",{Size=UDim2.new(1,0,0,0),ClipsDescendants=true,
                BackgroundTransparency=1,Parent=outer,})
            local bodyInner=New("Frame",{Size=UDim2.new(1,-16,0,0),AutomaticSize=Enum.AutomaticSize.Y,
                Position=UDim2.fromOffset(12,0),BackgroundTransparency=1,Parent=body,},{
                New("UIListLayout",{Padding=UDim.new(0,4),SortOrder=Enum.SortOrder.LayoutOrder}),
                New("UIPadding",{PaddingBottom=UDim.new(0,10)}),
            })
            if not open then body.Visible=false end
            header.MouseButton1Click:Connect(function()
                open=not open; arr.Text=open and "▲" or "▼"
                if open then
                    body.Visible=true
                    Tw(body,ANIM,{Size=UDim2.new(1,0,0,bodyInner.AbsoluteSize.Y+12)})
                else
                    Tw(body,ANIM,{Size=UDim2.new(1,0,0,0)}); task.wait(ANIM+0.02); body.Visible=false
                end
            end)
            local acc={Type="Accordion",Open=open,Section={Container=bodyInner}}
            Library.Options[idx]=acc; return acc
        end

        -- ── LiveLabel ─────────────────────────────
        function Tab:CreateLiveLabel(idx, cfg)
            cfg=cfg or {}
            local tCols={default=PAL.SubText,info=PAL.Info,success=PAL.Good,warning=PAL.Warn,error=PAL.Bad}
            local t=cfg.Type or "default"; local col=tCols[t] or tCols.default
            local row,_=MakeRow(page,cfg.Title or idx,cfg.Description,tabAccent)
            local pill=New("Frame",{AutomaticSize=Enum.AutomaticSize.XY,
                AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-10,0.5,0),
                BackgroundColor3=col,BackgroundTransparency=0.78,
                Visible=(cfg.Text or "")~="",Parent=row,ZIndex=4,},{
                New("UIStroke",{Color=col,Transparency=0.4,Thickness=1,ApplyStrokeMode=Enum.ApplyStrokeMode.Border}),
                New("UIPadding",{PaddingLeft=UDim.new(0,6),PaddingRight=UDim.new(0,6),
                    PaddingTop=UDim.new(0,2),PaddingBottom=UDim.new(0,2)}),
            })
            local vLbl=New("TextLabel",{Text=cfg.Text or "",
                FontFace=Font.new("rbxasset://fonts/families/RobotoMono.json",Enum.FontWeight.Medium),
                TextSize=10,TextColor3=col,TextXAlignment=Enum.TextXAlignment.Right,
                BackgroundTransparency=1,Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
                Parent=pill,})
            local stroke=pill:FindFirstChildOfClass("UIStroke")
            local ll={Value=cfg.Text or "",Type="LiveLabel"}
            function ll:SetText(text) self.Value=text or ""; vLbl.Text=self.Value; pill.Visible=self.Value~="" end
            function ll:SetType(tp)
                local c=tCols[tp] or tCols.default
                Tw(pill,0.2,{BackgroundColor3=c}); Tw(vLbl,0.2,{TextColor3=c})
                if stroke then Tw(stroke,0.2,{Color=c}) end
            end
            Library.Options[idx]=ll; return ll
        end

        return Tab
    end -- CreateTab

