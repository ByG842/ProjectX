            return { Set = function(_, t) tLbl.Text=t.Title; cLbl.Text=t.Content end }
        end

        -- ── Button ────────────────────────────────
        function Tab:CreateButton(cfg)
            local row, shard = MakeRow(page, cfg.Name, cfg.Description, tabAccent)
            -- arrow glyph right-side
            New("TextLabel", {
                Text="▶", FontFace=Font.new("rbxasset://fonts/families/RobotoMono.json",Enum.FontWeight.Bold),
                TextSize=10, TextColor3=tabAccent, BackgroundTransparency=1,
                Size=UDim2.fromOffset(14,14),
                Position=UDim2.new(1,-20,0.5,-7),
                Parent=row, ZIndex=4,
            })
            local ib = New("TextButton", {
                Size=UDim2.fromScale(1,1), BackgroundTransparency=1, Text="", Parent=row, ZIndex=6,
            })
            ib.MouseButton1Click:Connect(function()
                Tw(row,   0.08, { BackgroundColor3 = Color3.fromRGB(25,28,38) })
                Tw(shard, 0.08, { BackgroundTransparency = 0 })
                task.wait(0.09)
                Tw(row,   0.25, { BackgroundColor3 = PAL.PanelB })
                Tw(shard, 0.25, { BackgroundTransparency = 0.55 })
                Call(cfg.Callback)
                SaveCfg()
            end)
            return { Set = function(_, n) row:FindFirstChildWhichIsA("TextLabel").Text = n end }
        end

        -- ── Toggle ────────────────────────────────
        function Tab:CreateToggle(cfg)
            cfg.Type = "Toggle"
            local val = cfg.CurrentValue or false
            local row, _ = MakeRow(page, cfg.Name, cfg.Description, tabAccent)

            -- custom pill: flat rectangle with inner sliding block
            local track = New("Frame", {
                Size             = UDim2.fromOffset(40,20),
                Position         = UDim2.new(1,-50,0.5,-10),
                BackgroundColor3 = val and tabAccent or PAL.Dim,
                BackgroundTransparency = val and 0.4 or 0.2,
                Parent           = row, ZIndex=4,
            })
            New("UIStroke", {
                Color = val and tabAccent or PAL.Border,
                Thickness=1, Transparency=0.3,
                ApplyStrokeMode=Enum.ApplyStrokeMode.Border,
                Parent=track,
            })
            local knob = New("Frame", {
                Size             = UDim2.fromOffset(14,14),
                Position         = val and UDim2.fromOffset(23,3) or UDim2.fromOffset(3,3),
                BackgroundColor3 = val and tabAccent or PAL.SubText,
                Parent           = track, ZIndex=5,
            })

            local function setV(v)
                local stroke = track:FindFirstChildOfClass("UIStroke")
                Tw(track, 0.2, { BackgroundColor3 = v and tabAccent or PAL.Dim,
                                  BackgroundTransparency = v and 0.4 or 0.2 })
                if stroke then Tw(stroke, 0.2, { Color = v and tabAccent or PAL.Border }) end
                Tw(knob, 0.2, { Position = v and UDim2.fromOffset(23,3) or UDim2.fromOffset(3,3),
                                BackgroundColor3 = v and tabAccent or PAL.SubText })
            end
            setV(val)

            local ib = New("TextButton",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text="",Parent=row,ZIndex=6})
            ib.MouseButton1Click:Connect(function()
                val = not val; cfg.CurrentValue = val
                setV(val); Call(cfg.Callback, val); SaveCfg()
            end)
            function cfg:Set(v) val=v; cfg.CurrentValue=v; setV(v); Call(cfg.Callback,v) end
            if cfg.Flag then Library.Flags[cfg.Flag] = cfg end
            return cfg
        end

        -- ── Slider ────────────────────────────────
        function Tab:CreateSlider(cfg)
            cfg.Type = "Slider"
            local mn = cfg.Range and cfg.Range[1] or 0
            local mx = cfg.Range and cfg.Range[2] or 100
            local val = math.clamp(cfg.CurrentValue or mn, mn, mx)
            local row, _ = MakeRow(page, cfg.Name, cfg.Description, tabAccent)
            row.Size = UDim2.new(1,-12,0, cfg.Description~="" and 68 or 58)

            local vLbl = New("TextLabel", {
                Text=tostring(val)..(cfg.Suffix or ""),
                FontFace=Font.new("rbxasset://fonts/families/RobotoMono.json",Enum.FontWeight.Bold),
                TextSize=11, TextColor3=tabAccent, BackgroundTransparency=1,
                Size=UDim2.fromOffset(55,14),
                Position=UDim2.new(1,-60,0,cfg.Description~="" and 10 or 10),
                TextXAlignment=Enum.TextXAlignment.Right,
                Parent=row, ZIndex=4,
            })
            local railY = cfg.Description~="" and 38 or 34
            local rail = New("Frame", {
                Size=UDim2.new(1,-20,0,3),
                Position=UDim2.fromOffset(10,railY),
                BackgroundColor3=PAL.Border,
                Parent=row, ZIndex=4,
            })
            local fill = New("Frame", {
                Size=UDim2.new((val-mn)/(mx-mn),0,1,0),
                BackgroundColor3=tabAccent,
                Parent=rail, ZIndex=5,
            })
            -- tick mark at cursor
            local thumb = New("Frame", {
                Size=UDim2.fromOffset(8,14),
                AnchorPoint=Vector2.new(0.5,0.5),
                Position=UDim2.new((val-mn)/(mx-mn),0,0.5,0),
                BackgroundColor3=tabAccent,
                Parent=rail, ZIndex=6,
            })
            New("UIStroke",{Color=PAL.Bg,Thickness=1,ApplyStrokeMode=Enum.ApplyStrokeMode.Border,Parent=thumb})

            local dragging=false
            local ib=New("TextButton",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text="",Parent=row,ZIndex=7})
            ib.MouseButton1Down:Connect(function() dragging=true end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
            end)
            RunService.RenderStepped:Connect(function()
                if dragging then
                    local rx = math.clamp(UserInputService:GetMouseLocation().X - rail.AbsolutePosition.X, 0, rail.AbsoluteSize.X)
                    local pct = rx/rail.AbsoluteSize.X
                    val = math.floor(mn + pct*(mx-mn) + 0.5)
                    cfg.CurrentValue = val
                    local fp = (val-mn)/math.max(mx-mn,1)
                    fill.Size = UDim2.new(fp,0,1,0)
                    thumb.Position = UDim2.new(fp,0,0.5,0)
                    vLbl.Text = tostring(val)..(cfg.Suffix or "")
                    Call(cfg.Callback, val); SaveCfg()
                end
            end)
            function cfg:Set(v)
                val=math.clamp(v,mn,mx); cfg.CurrentValue=val
                local fp=(val-mn)/math.max(mx-mn,1)
                fill.Size=UDim2.new(fp,0,1,0); thumb.Position=UDim2.new(fp,0,0.5,0)
                vLbl.Text=tostring(val)..(cfg.Suffix or "")
            end
            if cfg.Flag then Library.Flags[cfg.Flag]=cfg end
            return cfg
        end

        -- ── Dropdown ──────────────────────────────
        function Tab:CreateDropdown(cfg)
            cfg.Type="Dropdown"
            if type(cfg.CurrentOption)=="string" then cfg.CurrentOption={cfg.CurrentOption} end
            cfg.CurrentOption = cfg.CurrentOption or {}
            local opened=false
            local row, _ = MakeRow(page, cfg.Name, cfg.Description, tabAccent)

            local selLbl = New("TextLabel", {
                Text=cfg.CurrentOption[1] or "none",
                FontFace=Font.new("rbxasset://fonts/families/RobotoMono.json"),
                TextSize=11, TextColor3=tabAccent, BackgroundTransparency=1,
                Size=UDim2.fromOffset(120,14),
                Position=UDim2.new(1,-130,0.5,-7),
                TextXAlignment=Enum.TextXAlignment.Right,
                Parent=row, ZIndex=4,
            })
            local arr = New("TextLabel",{
                Text="▼", FontFace=Font.new("rbxasset://fonts/families/RobotoMono.json",Enum.FontWeight.Bold),
                TextSize=9, TextColor3=PAL.SubText, BackgroundTransparency=1,
                Size=UDim2.fromOffset(12,12),
                Position=UDim2.new(1,-14,0.5,-6),
                Parent=row, ZIndex=4,
            })

            local listFrame = New("ScrollingFrame",{
                Size=UDim2.new(1,-12,0,0),
                Position=UDim2.fromOffset(6,0),
                BackgroundColor3=PAL.Panel,
                ScrollBarThickness=2,ScrollBarImageColor3=tabAccent,
                CanvasSize=UDim2.fromOffset(0,0), AutomaticCanvasSize=Enum.AutomaticSize.Y,
                Visible=false, ClipsDescendants=true,
                Parent=page, ZIndex=10,
            },{
                New("UIListLayout",{Padding=UDim.new(0,0),SortOrder=Enum.SortOrder.LayoutOrder}),
                New("UIStroke",{Color=PAL.Border,Thickness=1,ApplyStrokeMode=Enum.ApplyStrokeMode.Border}),
            })

            for _, opt in ipairs(cfg.Options or {}) do
                local ob = New("TextButton",{
                    Size=UDim2.new(1,0,0,28),
                    BackgroundColor3=table.find(cfg.CurrentOption,opt) and PAL.PanelB or PAL.Panel,
                    BackgroundTransparency=0,
                    Text=opt,
                    FontFace=Font.new("rbxasset://fonts/families/RobotoMono.json"),
                    TextSize=11, TextColor3=table.find(cfg.CurrentOption,opt) and tabAccent or PAL.Text,
                    TextXAlignment=Enum.TextXAlignment.Left,
                    Parent=listFrame, ZIndex=11,
                },{
                    New("UIPadding",{PaddingLeft=UDim.new(0,10)}),
                    New("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),
                                  BackgroundColor3=PAL.Border,BackgroundTransparency=0.4}),
                })
                ob.MouseButton1Click:Connect(function()
                    if not cfg.MultipleOptions then
                        cfg.CurrentOption={opt}; selLbl.Text=opt
                        opened=false; arr.Text="▼"
                        Tw(listFrame,0.18,{Size=UDim2.new(1,-12,0,0)})
                        task.wait(0.2); listFrame.Visible=false
                    else
                        local idx=table.find(cfg.CurrentOption,opt)
                        if idx then table.remove(cfg.CurrentOption,idx) else table.insert(cfg.CurrentOption,opt) end
                        selLbl.Text=#cfg.CurrentOption==0 and "none" or #cfg.CurrentOption==1 and cfg.CurrentOption[1] or "mixed"
                    end
                    for _,c in ipairs(listFrame:GetChildren()) do
                        if c:IsA("TextButton") then
                            c.TextColor3=table.find(cfg.CurrentOption,c.Text) and tabAccent or PAL.Text
                            c.BackgroundColor3=table.find(cfg.CurrentOption,c.Text) and PAL.PanelB or PAL.Panel
                        end
                    end
                    Call(cfg.Callback, cfg.CurrentOption); SaveCfg()
                end)
            end

            local ib=New("TextButton",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text="",Parent=row,ZIndex=6})
            ib.MouseButton1Click:Connect(function()
                opened=not opened
                if opened then
                    listFrame.Visible=true; arr.Text="▲"
                    Tw(listFrame,0.22,{Size=UDim2.new(1,-12,0,math.min(#(cfg.Options or {}),6)*28+2)})
                else
                    arr.Text="▼"
                    Tw(listFrame,0.18,{Size=UDim2.new(1,-12,0,0)})
                    task.wait(0.2); listFrame.Visible=false
                end
            end)

            function cfg:Set(v)
                if type(v)=="string" then v={v} end
                cfg.CurrentOption=v
                selLbl.Text=#v==0 and "none" or #v==1 and v[1] or "mixed"
            end
            if cfg.Flag then Library.Flags[cfg.Flag]=cfg end
            return cfg
        end

        -- ── Input ─────────────────────────────────
        function Tab:CreateInput(cfg)
            local row, _ = MakeRow(page, cfg.Name, cfg.Description, tabAccent)
            local iFrame = New("Frame",{
                Size=UDim2.fromOffset(148,24),
                Position=UDim2.new(1,-158,0.5,-12),
                BackgroundColor3=PAL.Panel,
                Parent=row, ZIndex=4,
            })
            New("UIStroke",{Color=PAL.Border,Thickness=1,
                             ApplyStrokeMode=Enum.ApplyStrokeMode.Border,Parent=iFrame})
            local box = New("TextBox",{
                Size=UDim2.new(1,-12,1,0), Position=UDim2.fromOffset(6,0),
                BackgroundTransparency=1,
                FontFace=Font.new("rbxasset://fonts/families/RobotoMono.json"),
                TextSize=11, TextColor3=PAL.Text,
                PlaceholderColor3=PAL.SubText, PlaceholderText=cfg.PlaceholderText or "",
                TextXAlignment=Enum.TextXAlignment.Left,
                ClearTextOnFocus=cfg.ClearTextOnFocus~=false,
                Parent=iFrame,
            })
            local stroke=iFrame:FindFirstChildOfClass("UIStroke")
            box.Focused:Connect(function() Tw(stroke,0.15,{Color=tabAccent}) end)
            box.FocusLost:Connect(function()
                Tw(stroke,0.2,{Color=PAL.Border})
                Call(cfg.Callback,box.Text)
                if cfg.RemoveTextAfterFocusLost then box.Text="" end
                SaveCfg()
            end)
            local v={}; function v:Set(t) box.Text=t end; return v
        end

        -- ── ColorPicker ───────────────────────────
        function Tab:CreateColorPicker(cfg)
            cfg.Type="ColorPicker"
            local h,s,v=(cfg.Color or Color3.fromRGB(255,0,0)):ToHSV()
            local row,_=MakeRow(page,cfg.Name,cfg.Description,tabAccent)
            local swatch=New("TextButton",{
                Size=UDim2.fromOffset(32,20),
                Position=UDim2.new(1,-42,0.5,-10),
                BackgroundColor3=Color3.fromHSV(h,s,v),
                Text="", Parent=row, ZIndex=5,
            })
            New("UIStroke",{Color=PAL.Border,Thickness=1,ApplyStrokeMode=Enum.ApplyStrokeMode.Border,Parent=swatch})

            local picker=New("Frame",{
                Size=UDim2.fromOffset(210,130), Position=UDim2.new(1,-220,1,4),
                BackgroundColor3=PAL.Panel, Visible=false, Parent=row, ZIndex=20,
            })
            New("UIStroke",{Color=tabAccent,Thickness=1,Transparency=0.5,
                             ApplyStrokeMode=Enum.ApplyStrokeMode.Border,Parent=picker})

            local canvas=New("ImageButton",{
                Size=UDim2.new(1,-48,1,-20),Position=UDim2.fromOffset(6,6),
                Image="rbxassetid://11415645739",
                BackgroundColor3=Color3.fromHSV(h,1,1),
                Parent=picker,ZIndex=21,
            })
            local svK=New("Frame",{Size=UDim2.fromOffset(8,8),AnchorPoint=Vector2.new(0.5,0.5),
                Position=UDim2.new(s,0,1-v,0),BackgroundColor3=Color3.fromHSV(h,s,v),
                Parent=canvas,ZIndex=22,
            })
            New("UIStroke",{Color=Color3.new(1,1,1),Thickness=1.5,ApplyStrokeMode=Enum.ApplyStrokeMode.Border,Parent=svK})

            local hRail=New("Frame",{Size=UDim2.new(0,16,1,-20),Position=UDim2.new(1,-28,0,6),
                Parent=picker,ZIndex=21,
            })
            New("UIGradient",{Rotation=90,Color=ColorSequence.new({
                ColorSequenceKeypoint.new(0,Color3.fromRGB(255,0,0)),
                ColorSequenceKeypoint.new(0.17,Color3.fromRGB(255,255,0)),
                ColorSequenceKeypoint.new(0.33,Color3.fromRGB(0,255,0)),
                ColorSequenceKeypoint.new(0.5,Color3.fromRGB(0,255,255)),
                ColorSequenceKeypoint.new(0.67,Color3.fromRGB(0,0,255)),
                ColorSequenceKeypoint.new(0.83,Color3.fromRGB(255,0,255)),
                ColorSequenceKeypoint.new(1,Color3.fromRGB(255,0,0)),
            }),Parent=hRail})
            local hK=New("Frame",{Size=UDim2.new(1,4,0,4),Position=UDim2.new(0,-2,h,-2),
                BackgroundColor3=Color3.new(1,1,1),Parent=hRail,ZIndex=22,})
            local hexBox=New("TextBox",{Size=UDim2.new(1,-12,0,18),Position=UDim2.new(0,6,1,-22),
                BackgroundColor3=PAL.PanelB,FontFace=Font.new("rbxasset://fonts/families/RobotoMono.json"),
                TextSize=10,TextColor3=PAL.Text,TextXAlignment=Enum.TextXAlignment.Center,
                Text=string.format("#%02X%02X%02X",
                    math.floor(Color3.fromHSV(h,s,v).R*255+0.5),
                    math.floor(Color3.fromHSV(h,s,v).G*255+0.5),
                    math.floor(Color3.fromHSV(h,s,v).B*255+0.5)),
                Parent=picker,ZIndex=22,
            })

            local function upd()
                local c=Color3.fromHSV(h,s,v)
                swatch.BackgroundColor3=c; canvas.BackgroundColor3=Color3.fromHSV(h,1,1)
                svK.Position=UDim2.new(s,0,1-v,0); svK.BackgroundColor3=c
                hK.Position=UDim2.new(0,-2,h,-2)
                hexBox.Text=string.format("#%02X%02X%02X",math.floor(c.R*255+0.5),math.floor(c.G*255+0.5),math.floor(c.B*255+0.5))
                cfg.Color=c; Call(cfg.Callback,c); SaveCfg()
            end

            local svD,hD=false,false
            canvas.MouseButton1Down:Connect(function() svD=true end)
            hRail.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then hD=true end end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then svD=false;hD=false end
            end)
            RunService.RenderStepped:Connect(function()
                if svD then
                    local m=UserInputService:GetMouseLocation()
                    s=math.clamp((m.X-canvas.AbsolutePosition.X)/canvas.AbsoluteSize.X,0,1)
                    v=1-math.clamp((m.Y-canvas.AbsolutePosition.Y)/canvas.AbsoluteSize.Y,0,1)
                    upd()
                end
                if hD then
                    h=math.clamp((UserInputService:GetMouseLocation().Y-hRail.AbsolutePosition.Y)/hRail.AbsoluteSize.Y,0,1)
                    upd()
                end
            end)

            local open=false
            swatch.MouseButton1Click:Connect(function() open=not open; picker.Visible=open end)
