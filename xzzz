--  Element row factory  — "Neon Shard" style
--  Sharp corners, left rail bar, subtle bottom divider line
-- ══════════════════════════════════════════════════════════════
local function MakeRow(parent, title, desc, accent)
    accent = accent or PAL.Accent

    local row = New("Frame", {
        Size             = UDim2.new(1, -12, 0, desc and desc~="" and 52 or 42),
        BackgroundColor3 = PAL.PanelB,
        Parent           = parent,
    })

    -- left accent shard (2px wide, 60% height)
    local shard = New("Frame", {
        Size             = UDim2.new(0, 2, 0, 24),
        Position         = UDim2.new(0, 0, 0.5, -12),
        BackgroundColor3 = accent,
        BackgroundTransparency = 0.55,
        Parent           = row,
        ZIndex           = 3,
    })

    -- bottom border line
    New("Frame", {
        Size             = UDim2.new(1, -4, 0, 1),
        Position         = UDim2.fromOffset(2, 0),
        AnchorPoint      = Vector2.new(0, 1),
        BackgroundColor3 = PAL.Border,
        BackgroundTransparency = 0.3,
        Parent           = row,
    })

    -- title
    New("TextLabel", {
        Text           = title or "",
        FontFace       = Font.new("rbxasset://fonts/families/RobotoMono.json", Enum.FontWeight.Medium),
        TextSize       = 12,
        TextColor3     = PAL.Text,
        TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        Size           = UDim2.new(0.55, -14, 0, 16),
        Position       = UDim2.fromOffset(12, desc and desc~="" and 8 or 13),
        Parent         = row,
    })

    if desc and desc ~= "" then
        New("TextLabel", {
            Text           = desc,
            FontFace       = Font.new("rbxasset://fonts/families/RobotoMono.json"),
            TextSize       = 10,
            TextColor3     = PAL.SubText,
            TextXAlignment = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1,
            Size           = UDim2.new(0.7, -14, 0, 14),
            Position       = UDim2.fromOffset(12, 28),
            Parent         = row,
        })
    end

    -- hover glow
    row.MouseEnter:Connect(function()
        Tw(row,   0.12, { BackgroundColor3 = Color3.fromRGB(22, 22, 32) })
        Tw(shard, 0.12, { BackgroundTransparency = 0.15 })
    end)
    row.MouseLeave:Connect(function()
        Tw(row,   0.2, { BackgroundColor3 = PAL.PanelB })
        Tw(shard, 0.2, { BackgroundTransparency = 0.55 })
    end)

    return row, shard
end

