                })
            end
            local pB=mkSB("▶"); local rB=mkSB("↺")
            local tim={Value=startV,Running=false,Type="Timer"}
            local conn
            local function stop() if conn then conn:Disconnect();conn=nil end end
            local function start()
                stop(); conn=RunService.Heartbeat:Connect(function(dt)
                    if running then
                        tim.Value=tim.Value+(countdown and -dt or dt)
                        tLbl.Text=fmt(tim.Value); Call(cfg.Callback,tim.Value)
                        if countdown and tim.Value<=0 then
                            tim.Value=0;running=false;pB.Text="▶";stop();Call(cfg.OnEnd)
                        end
                    end
                end)
            end
            pB.MouseButton1Click:Connect(function()
                running=not running;tim.Running=running
                pB.Text=running and "⏸" or "▶"
                if running then start() else stop() end
            end)
            rB.MouseButton1Click:Connect(function()
                running=false;tim.Running=false;pB.Text="▶";stop()
                tim.Value=startV;tLbl.Text=fmt(startV)
            end)
            function tim:Destroy() stop();row:Destroy() end
            Library.Options[idx]=tim; return tim
        end

