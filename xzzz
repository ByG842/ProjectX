    -- ══════════════════════════════════════════════
    local Window = {}
    function Window:Notify(cfg) Library:Notify(cfg) end
    function Window:Destroy() SG:Destroy() end

    -- ── CreateTab ─────────────────────────────────
    function Window:CreateTab(name, imageId)
        local page = New("ScrollingFrame", {
            Name                = name,
            Size                = UDim2.new(1, -6, 1, -6),
            Position            = UDim2.fromOffset(3, 3),
            BackgroundTransparency = 1,
            ScrollBarThickness  = 2,
            ScrollBarImageColor3= accent,
            CanvasSize          = UDim2.fromOffset(0,0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            Visible             = false,
            Parent              = ContentBg,
            ZIndex              = 3,
        }, {
            New("UIListLayout", { Padding = UDim.new(0,3), SortOrder = Enum.SortOrder.LayoutOrder }),
            New("UIPadding", { PaddingTop=UDim.new(0,4), PaddingBottom=UDim.new(0,8),
                               PaddingLeft=UDim.new(0,0), PaddingRight=UDim.new(0,2) }),
        })
        table.insert(TabPages, page)

        -- Rail button
        local tabBtn = New("TextButton", {
            Size                   = UDim2.new(1, -1, 0, 38),
            BackgroundTransparency = 1,
            Text                   = "",
            Parent                 = TabList,
            ZIndex                 = 6,
        })

        -- hover bg
        local tabBg = New("Frame", {
            Size             = UDim2.fromScale(1,1),
            BackgroundColor3 = PAL.PanelB,
            BackgroundTransparency = 1,
            ZIndex           = 5,
            Parent           = tabBtn,
        })

        -- selected bar (right-edge, like VSCode)
        local tabBar = New("Frame", {
            Size             = UDim2.new(0, 2, 0, 22),
            Position         = UDim2.new(1,-2,0.5,-11),
            BackgroundColor3 = accent,
            BackgroundTransparency = 1,
            ZIndex           = 7,
            Parent           = tabBtn,
        })

        -- icon
        local tabIcon = New("ImageLabel", {
            Image            = imageId and ("rbxassetid://"..tostring(imageId)) or "",
            Size             = UDim2.fromOffset(16,16),
            Position         = UDim2.new(0,10,0.5,-8),
            BackgroundTransparency = 1,
            ImageColor3      = PAL.SubText,
            ZIndex           = 7,
            Parent           = tabBtn,
        })

        local tabLbl = New("TextLabel", {
            Text           = name,
            FontFace       = Font.new("rbxasset://fonts/families/RobotoMono.json", Enum.FontWeight.Medium),
            TextSize       = 11,
            TextColor3     = PAL.SubText,
            TextXAlignment = Enum.TextXAlignment.Left,
            BackgroundTransparency = 1,
            Size           = UDim2.new(1,-34,1,0),
            Position       = UDim2.fromOffset(32,0),
            ZIndex         = 7,
            Parent         = tabBtn,
        })

        -- bottom rule
        New("Frame", {
            Size             = UDim2.new(1,0,0,1),
            Position         = UDim2.new(0,0,1,-1),
            BackgroundColor3 = PAL.Border,
            BackgroundTransparency = 0.5,
            Parent           = tabBtn,
        })

        local ref = { Bar=tabBar, Lbl=tabLbl, Icon=tabIcon, Bg=tabBg }
        table.insert(TabBtns, ref)
        tabBtn.MouseButton1Click:Connect(function() SelectTab(ref, page) end)
        tabBtn.MouseEnter:Connect(function() Tw(tabBg, 0.1, { BackgroundTransparency = 0.92 }) end)
        tabBtn.MouseLeave:Connect(function() Tw(tabBg, 0.15, { BackgroundTransparency = 1 }) end)

        if #TabPages == 1 then SelectTab(ref, page) end

        -- ══════════════════════════════════════════
        --  Tab object
        -- ══════════════════════════════════════════
        local Tab = {}
        local tabAccent = accent  -- each tab uses same accent (could vary)

        -- ── Section ───────────────────────────────
        function Tab:CreateSection(sectionName)
            if #page:GetChildren() > 2 then
                New("Frame", { Size=UDim2.new(1,0,0,8), BackgroundTransparency=1, Parent=page })
            end
            local bar = New("Frame", {
                Size             = UDim2.new(1,-12,0,22),
                BackgroundColor3 = PAL.Panel,
                Parent           = page,
                ZIndex           = 3,
            })
            -- left accent
            New("Frame", {
                Size             = UDim2.new(0,3,1,0),
                BackgroundColor3 = tabAccent,
                Parent           = bar,
            })
            New("TextLabel", {
                Text           = (sectionName or ""):upper(),
                FontFace       = Font.new("rbxasset://fonts/families/RobotoMono.json", Enum.FontWeight.Bold),
                TextSize       = 10,
                TextColor3     = tabAccent,
                TextXAlignment = Enum.TextXAlignment.Left,
                BackgroundTransparency = 1,
                Size           = UDim2.new(1,-14,1,0),
                Position       = UDim2.fromOffset(10,0),
                Parent         = bar,
            })
            return { Set = function(_, t)
                bar:FindFirstChildWhichIsA("TextLabel").Text = t:upper()
            end }
        end

        -- ── Label ─────────────────────────────────
        function Tab:CreateLabel(text)
            local row, _ = MakeRow(page, text, nil, tabAccent)
            return { Set = function(_, t)
                row:FindFirstChildWhichIsA("TextLabel").Text = t
            end }
        end

        -- ── Paragraph ─────────────────────────────
        function Tab:CreateParagraph(cfg)
            local frame = New("Frame", {
                Size             = UDim2.new(1,-12,0,0),
                AutomaticSize    = Enum.AutomaticSize.Y,
                BackgroundColor3 = PAL.PanelB,
                Parent           = page,
            })
            New("Frame", { Size=UDim2.new(0,2,1,0), BackgroundColor3=tabAccent,
                            BackgroundTransparency=0.55, Parent=frame })
            New("Frame", { Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1),
                            BackgroundColor3=PAL.Border, BackgroundTransparency=0.3, Parent=frame })
            local inner = New("Frame", {
                Size             = UDim2.new(1,-14,0,0),
                AutomaticSize    = Enum.AutomaticSize.Y,
                Position         = UDim2.fromOffset(14,8),
                BackgroundTransparency = 1,
                Parent           = frame,
            }, {
                New("UIListLayout", { Padding=UDim.new(0,4), SortOrder=Enum.SortOrder.LayoutOrder }),
                New("UIPadding",    { PaddingBottom=UDim.new(0,10) }),
            })
            local tLbl = New("TextLabel", {
                Text=cfg.Title or "", FontFace=Font.new("rbxasset://fonts/families/RobotoMono.json",Enum.FontWeight.Bold),
                TextSize=12, TextColor3=PAL.Text, TextXAlignment=Enum.TextXAlignment.Left,
                BackgroundTransparency=1, Size=UDim2.new(1,0,0,16), Parent=inner, LayoutOrder=1,
            })
            local cLbl = New("TextLabel", {
                Text=cfg.Content or "", FontFace=Font.new("rbxasset://fonts/families/RobotoMono.json"),
                TextSize=11, TextColor3=PAL.SubText, TextWrapped=true,
                TextXAlignment=Enum.TextXAlignment.Left,
                BackgroundTransparency=1, Size=UDim2.new(1,0,0,0),
                AutomaticSize=Enum.AutomaticSize.Y, Parent=inner, LayoutOrder=2,
