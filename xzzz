    task.delay(3.5, function()
        if COn then pcall(function()
            if isfile(ConfigurationFolder.."/"..CFile..ConfigurationExtension) then
                LoadCfg(readfile(ConfigurationFolder.."/"..CFile..ConfigurationExtension))
                Library:Notify({Title="Config",Content="Previous session loaded.",Accent=accent})
            end
        end) end
    end)

    return Window
end -- CreateWindow

return Library
