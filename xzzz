-- ── Helpers ───────────────────────────────────────────────────
local function New(cls, props, children)
    local o = Instance.new(cls)
    for k, v in pairs(props or {}) do
        if k ~= "Parent" then pcall(function() o[k] = v end) end
    end
    for _, c in ipairs(children or {}) do
        if c then c.Parent = o end
    end
    if props and props.Parent then o.Parent = props.Parent end
    return o
end

local function Tw(inst, t, props, style)
    TweenService:Create(inst,
        TweenInfo.new(t, style or Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
        props):Play()
end

local function Call(fn, ...)
    if type(fn) == "function" then
        local ok, e = pcall(fn, ...)
        if not ok then warn("[FusionUI] " .. tostring(e)) end
    end
end

local function Draggable(handle, target)
    local drag, di, mp, fp = false
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            drag = true; mp = i.Position; fp = target.Position
            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.End then drag = false end
            end)
        end
    end)
    handle.InputChanged:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseMovement then di = i end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if i == di and drag then
            local d = i.Position - mp
            Tw(target, 0.07, { Position = UDim2.new(
                fp.X.Scale, fp.X.Offset + d.X,
                fp.Y.Scale, fp.Y.Offset + d.Y
            )}, Enum.EasingStyle.Linear)
        end
    end)
end

